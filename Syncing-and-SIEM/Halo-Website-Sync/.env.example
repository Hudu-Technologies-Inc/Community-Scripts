export HUDU_API_KEY=
export HUDU_INSTANCE_URL=
export HALO_BASE_URL=
export HALO_CLIENT_ID=
export HALO_CLIENT_SECRET=
export HALO_TENANT=

# Halo asset type name for synced websites (matched case-insensitively via GET /api/AssetType)
export HALO_ASSET_TYPE_NAME=Workstation

# Optional: use when Hudu company names do not match Halo client names
export HALO_DEFAULT_CLIENT_ID=
# Optional JSON map of Hudu company_id -> Halo client_id, e.g. {"1": 26, "2": 40}
export HUDU_HALO_CLIENT_MAP=

# Set to 1 to also query live DNS (SPF/DMARC/TXT/MX) via Cloudflare DoH when Hudu has no record text
export SYNC_LIVE_DNS=1

# Optional: map Halo asset-type field labels to Hudu metadata keys, e.g.
# {"Last DNS check":"refreshed_at","SPF tracking":"enable_spf_tracking"}
export HALO_WEBSITE_FIELD_MAP=

# Expirations: synced automatically from GET /expirations, matched by:
# - Website ID (expirationable_type=Website)
# - website.asset_field_id (custom field expirations)
# Domain/SSL expiry dates are also written to Halo warranty_end when present.

# Asset notes include URLs for the live website (Hudu name/URL) and the Hudu Website Record (HUDU_INSTANCE_URL + /websites/{slug})
# (HUDU_INSTANCE_URL + website.url path, e.g. /websites/{slug}).
